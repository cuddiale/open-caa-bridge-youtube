{
  "manifest_version": 3,
  "name": "Open CAA Bridge YouTube",
  "version": "1.0",
  "description": "Barra laterale CAA per supportare la comunicazione su YouTube",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ]
}